# ============================================================
# OMNYX — environment variables
# Copy to .env and fill in secrets before running compose
# ============================================================

# ---- Tenant -------------------------------------------------
TENANT_ID=unicharm

# ---- PostgreSQL — Primary App DB (source + app schemas) -----
POSTGRES_DB=omnyx
POSTGRES_USER=omnyx
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# ---- TimescaleDB — Time-Series DB (telemetry only) ----------
TIMESCALE_DB=omnyx_ts
TIMESCALE_USER=omnyx
TIMESCALE_PASSWORD=change-me
TIMESCALE_PORT=5434

# ---- Kafka --------------------------------------------------
KAFKA_PORT=9092
KAFKA_UI_PORT=8080
# External listener for host-network services (dal-bacnet)
KAFKA_EXTERNAL=localhost:9095
# KRaft cluster ID — generate once with: docker run --rm apache/kafka:3.7.0 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg

# ---- Redis --------------------------------------------------
REDIS_PORT=6379

# ---- Keycloak -----------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_PORT=8081
# Secret for the omnyx-api confidential client
KEYCLOAK_API_SECRET=omnyx-api-secret-change-me

# ---- Grafana ------------------------------------------------
GRAFANA_ADMIN_PASSWORD=omnyx2024
GRAFANA_PORT=3000

# ---- Observability ports ------------------------------------
PROMETHEUS_PORT=9090
LOKI_PORT=3100

# ---- OMNYX services -----------------------------------------
FRONTEND_PORT=80
API_PORT=8000
WS_PORT=8765

# ---- LLM backend (claude | ollama) --------------------------
LLM_BACKEND=claude
ANTHROPIC_API_KEY=sk-ant-change-me
OLLAMA_URL=http://host.docker.internal:11434

# ---- Legacy Unicharm MySQL (dal-replay only) ----------------
UNICHARM_HOST=
UNICHARM_RO_PW=

# ---- Node env -----------------------------------------------
NODE_ENV=development
